{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heartbioportal.org/schemas/datahub/dataset_profile.schema.json",
  "title": "DataHub dataset profile",
  "type": "object",
  "required": ["name", "dataset_type", "field_policies"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "dataset_type": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "required_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "field_policies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required": { "type": "boolean" },
          "missing_strategy": { "enum": ["exclude", "unknown", "allow"] },
          "unknown_value": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
