{
  "name": "structural_variant",
  "dataset_type": "STRUCTURAL_VARIANT",
  "description": "Profile for structural variant ingestion and legacy per-gene SV publication.",
  "required_fields": [
    "gene_id",
    "variant_id"
  ],
  "field_policies": {
    "gene_id": {
      "required": true,
      "missing_strategy": "exclude"
    },
    "variant_id": {
      "required": true,
      "missing_strategy": "exclude"
    },
    "phenotype": {
      "required": false,
      "missing_strategy": "allow"
    },
    "variation_type": {
      "required": false,
      "missing_strategy": "allow",
      "unknown_value": "Unknown"
    },
    "clinical_significance": {
      "required": false,
      "missing_strategy": "allow",
      "unknown_value": "Unknown"
    }
  }
}
